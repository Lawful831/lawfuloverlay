# LawfulOverlay Server — environment configuration
# Copy this file to .env and fill in your real values.
# NEVER commit .env to version control.

# ── Required ────────────────────────────────────────────────────────────────

# Your Discord bot token (from https://discord.com/developers/applications)
DISCORD_BOT_TOKEN=your-bot-token-here

# Comma-separated Discord user IDs whose messages will be relayed
TARGET_USER_IDS=123456789,987654321

# The numeric Guild (server) ID to monitor
TARGET_SERVER_ID=111222333444555666

# ── Optional ─────────────────────────────────────────────────────────────────

# Host/port for the WebSocket server (defaults below)
WS_HOST=0.0.0.0
WS_PORT=8765
